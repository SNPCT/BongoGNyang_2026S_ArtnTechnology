{
  "name": "bongognyangformac",
  "version": "1.2.0",
  "description": "BongoGNyang Desktop Mascot for ArtnTechnology Class",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "H. Jang and J. Kwon",
  "license": "ISC",
  "dependencies": {
    "node-global-key-listener": "^0.1.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bongognyang.mac",
    "productName": "BongoGNyang",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.entertainment"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "node_modules/node-global-key-listener/**/*"
    ]
  }
}