{
  "name": "bongognyang",
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.hjang.bongognyang",
    "productName": "BongoGnyang",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*"
    ],
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist"
    },
    "dmg": {
      "title": "BongoGnyang Install"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "node-global-key-listener": "^0.1.1"
  }
}
